# Log File Configuration
LOG_FILE_PATH=logs/access.log

# Application Settings
APP_NAME=Context-Aware Web Attack Detection Framework
DEBUG=False

# AI Intent Analyzer (Groq API — free at console.groq.com)
AI_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.1-8b-instant
AI_ENABLED=True

# Flow/Session Detection
FLOW_DETECTION_ENABLED=True
FLOW_SESSION_TIMEOUT=300

# JWT Security
SECRET_KEY=change_this_to_a_strong_random_key
